{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "AI Discovery Workshop Agent Unified Schema",
    "type": "object",
    "properties": {
        "agents": {
            "type": "object",
            "additionalProperties": {
                "type": "object",
                "properties": {
                    "persona": {
                        "type": "string"
                    },
                    "document": {
                        "type": "string"
                    },
                    "documents": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "temperature": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 2
                    },
                    "model": {
                        "type": "string"
                    }
                },
                "required": [
                    "persona"
                ],
                "oneOf": [
                    {
                        "required": [
                            "document"
                        ]
                    },
                    {
                        "required": [
                            "documents"
                        ]
                    }
                ],
                "additionalProperties": false
            }
        },
        "sections": {
            "type": "object",
            "additionalProperties": {
                "type": "array",
                "items": {
                    "oneOf": [
                        {
                            "type": "object",
                            "required": [
                                "type",
                                "agent",
                                "title",
                                "icon",
                                "url_path",
                                "header",
                                "subtitle"
                            ],
                            "properties": {
                                "type": {
                                    "const": "agent"
                                },
                                "agent": {
                                    "type": "string"
                                },
                                "title": {
                                    "type": "string"
                                },
                                "icon": {
                                    "type": "string"
                                },
                                "url_path": {
                                    "type": "string"
                                },
                                "header": {
                                    "type": "string"
                                },
                                "subtitle": {
                                    "type": "string"
                                },
                                "admin_only": {
                                    "type": "boolean"
                                }
                            },
                            "additionalProperties": false
                        }
                    ]
                }
            }
        }
    },
    "required": [
        "agents",
        "sections"
    ],
    "additionalProperties": false
}
