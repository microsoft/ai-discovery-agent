{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: FastAPI",
      "type": "debugpy",
      "request": "launch",
      "cwd": "${workspaceFolder}/src",
      "python": "${workspaceFolder}/src/.venv/bin/python",
      "module": "uvicorn",
      "args": [
        "aida.__main__:app",
        "--reload",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "autoStartBrowser": true,
      "env": {
        "LOGLEVEL": "DEBUG"
      },
      "preLaunchTask": "preLaunch",
      "postDebugTask": "stop_azurite"
    },
    {
      "name": "Python Debugger: Chainlit",
      "type": "debugpy",
      "request": "launch",
      "cwd": "${workspaceFolder}/src",
      "python": "${workspaceFolder}/src/.venv/bin/python",
      "module": "chainlit",
      "args": [
        "run",
        "--debug",
        "-h",
        "-w",
        "chainlit.py",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "autoStartBrowser": true,
      "env": {
        "LOGLEVEL": "DEBUG"
      },
      "preLaunchTask": "preLaunch",
      "postDebugTask": "stop_azurite"
    }
  ]
}
