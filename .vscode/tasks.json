{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "start_azurite",
      "command": "${command:azurite.start_blob}",
      "problemMatcher": [],
      "isBackground": true
    },
    {
      "label": "stop_azurite",
      "command": "${command:azurite.close_blob}",
      "problemMatcher": [],
      "isBackground": true
    },
    {
      "label": "lint",
      "type": "shell",
      "command": "cd src && uv run pre-commit run --all-files -v",
      "group": "build"
    },
    {
      "label": "check-copyright-headers",
      "type": "shell",
      "command": "./scripts/check-copyright-headers.sh",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "build",
      "type": "shell",
      "command": "uv build --directory src",
      "group": "build",
      "problemMatcher": "$python",
      "dependsOn": [
        "lint"
      ]
    },
    {
      "label": "validate all",
      "group": "build",
      "dependsOn": [
        "build",
        "bandit",
        "bicep-checkov"
      ]
    },
    {
      "label": "bandit",
      "type": "shell",
      "command": "cd src && uv run bandit -c .bandit.yml -r .",
      "group": "test",
      "problemMatcher": "$python"
    },
    {
      "label": "bicep-validate",
      "type": "shell",
      "command": "bicep build infra/main.bicep --stdout --no-restore > /dev/null",
      "group": "test"
    },
    {
      "label": "bicep-checkov",
      "type": "shell",
      "command": "source src/.venv/bin/activate && uv run checkov -d ${workspaceFolder} --config-file ${workspaceFolder}/.checkov.yml --quiet",
      "group": "test",
      "dependsOn": [
        "bicep-validate"
      ]
    },
    {
      "label": "bicep-checkov-debug",
      "type": "shell",
      "command": "source src/.venv/bin/activate && LOG_LEVEL=debug uv run checkov -d ${workspaceFolder} --config-file ${workspaceFolder}/.checkov.yml --compact",
      "group": "test",
      "dependsOn": [
        "bicep-validate"
      ]
    },
    {
      "label": "preLaunch",
      "dependsOn": [
        "build",
        "start_azurite"
      ]
    },
    {
      "label": "generate-notice",
      "type": "shell",
      "command": "./scripts/generate-notice.sh",
      "args": [
        "--verbose"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "generate-notice-with-dev",
      "type": "shell",
      "command": "./scripts/generate-notice.sh",
      "args": [
        "--include-dev",
        "--verbose"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "prepareAzureDev",
      "type": "shell",
      "command": "./scripts/map-env-vars.sh",
      "windows": {
        "command": ".\\scripts\\test.cmd"
      },
      "presentation": {
        "reveal": "always"
      },
      "problemMatcher": []
    }
  ]
}